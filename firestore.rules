rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students/Users collection
    match /users/{userId} {
      // Anyone can read user profiles (needed for homepage and Connect page)
      allow read: if true;

      // Users can only write/update their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Instructors collection
    match /instructors/{instructorId} {
      // Anyone can read instructor profiles (for browsing)
      allow read: if true;

      // Only the instructor can write their own profile
      allow write: if request.auth != null
                   && request.auth.uid == instructorId;
    }

    // Conversations collection
    match /conversations/{conversationId} {
      // Users can read conversations they are a participant in
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Users can create new conversations where they are a participant
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      // Users can update conversations they are a participant in
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Users can read messages in conversations they're part of
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Users can create messages in conversations they're part of
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                      && request.auth.uid == request.resource.data.senderId;

        // Users can update their own messages (e.g., mark as read)
        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // Instructor availability
    match /instructor_availability/{instructorId} {
      // Anyone can read instructor availability (for students to browse)
      allow read: if true;

      // Only the instructor can write their own availability
      allow write: if request.auth != null && request.auth.uid == instructorId;
    }

    // Availability overrides (special dates)
    match /availability_overrides/{overrideId} {
      // Anyone can read overrides
      allow read: if true;

      // Only the instructor can write their own overrides
      allow write: if request.auth != null
                   && request.auth.uid == request.resource.data.instructorId;
    }

    // Bookings
    match /bookings/{bookingId} {
      // Any authenticated user can read bookings (needed to check instructor availability)
      allow read: if request.auth != null;

      // Students can create bookings (including Stripe payment fields:
      // paymentIntentId, paymentStatus, amount, currency)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.studentId
                    && request.resource.data.status == "confirmed";

      // Either party can cancel; instructor/student can mark booking as seen
      allow update: if request.auth != null && (
                      // Cancel: student or instructor
                      ((request.auth.uid == resource.data.instructorId
                        || request.auth.uid == resource.data.studentId)
                       && request.resource.data.status == 'cancelled')
                      ||
                      // Mark seen: only instructor, only the instructorSeen field
                      (request.auth.uid == resource.data.instructorId
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['instructorSeen']))
                      ||
                      // Mark seen: only student, only the studentSeen field
                      (request.auth.uid == resource.data.studentId
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentSeen']))
                    );
    }

    // Friend / Partner Requests
    match /friendRequests/{requestId} {
      // Authenticated users can send a request (must be the sender)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromId;

      // Sender and recipient can read the request
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromId
                      || request.auth.uid == resource.data.toId);

      // Only the recipient can respond (accept / decline)
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.toId
                    && request.resource.data.status in ['accepted', 'declined'];
    }

    // Email log collection (only Cloud Functions can write)
    match /emailLog/{logId} {
      // No client reads or writes - this is for server-side logging only
      allow read, write: if false;
    }

    // Admins collection — only an admin can verify their own status
    // New admins must be added via Firebase Console or Admin SDK
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // Contact messages logged from the contact form Cloud Function
    // Admin-read only; no client writes
    match /contactMessages/{messageId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if false;
    }

    // Whiteboard relay — ephemeral per-session drawing sync via onSnapshot
    // One document per participant per channel; deleted on leave
    match /whiteboard/{channelId}/relay/{docId} {
      allow read, write: if request.auth != null;
    }

    // Whiteboard text board — shared phrase messages during a call
    match /whiteboard/{channelId}/textboard/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Video call presence — each participant writes their Agora UID → name mapping
    // so remote participants can look up display names without a collection query
    match /video_calls/{channelName}/presence/{agoraUid} {
      allow read, write: if request.auth != null;
    }

    // Instructor reviews — submitted by students after a lesson
    match /reviews/{reviewId} {
      // Anyone can read reviews (they are public on instructor profiles)
      allow read: if true;

      // Only authenticated users can create a review, and only as themselves
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.studentId;

      // Reviews cannot be edited or deleted
      allow update, delete: if false;
    }

    // Platform stats — read-only for clients; written only by Cloud Functions (Admin SDK)
    match /platformStats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // User reports — submitted when a user reports another user's profile
    match /userReports/{reportId} {
      // Any logged-in user can submit a report (cannot report themselves)
      allow create: if request.auth != null
                   && request.resource.data.reporterId == request.auth.uid
                   && request.resource.data.reporterId != request.resource.data.reportedUserId;
      // Only admins can read or delete reports
      allow read, delete: if request.auth != null
                         && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update: if false;
    }
  }
}
