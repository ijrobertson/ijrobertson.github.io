rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatar images - users can only upload/read their own
    match /avatars/{userId} {
      allow read: if true;  // Anyone can view avatars
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');  // Images only
    }
    match /instructor_videos/{userId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }
    // Audio messages sent between users in a conversation
    match /conversations/{conversationId}/audio/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB per audio message
                   && request.resource.contentType.matches('audio/.*');
    }
  }
}
